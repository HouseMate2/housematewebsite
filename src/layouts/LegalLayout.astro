---
import BaseLayout from './BaseLayout.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

interface Props {
  title: string;
}
const { title } = Astro.props;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const updated = new Date().toLocaleDateString(lang === 'it' ? 'it-IT' : 'en-US');
---

<BaseLayout title={`${title} — HouseMate`}>
  <article class="py-20 md:py-24">
    <div class="container-page max-w-3xl">
      <h1 class="text-4xl font-bold tracking-tight sm:text-5xl">{title}</h1>
      <p class="mt-3 text-sm text-muted">
        {lang === 'it' ? 'Ultimo aggiornamento' : 'Last updated'}: {updated}
      </p>

      <div class="mt-6 rounded-xl border border-accent-400/40 bg-accent-400/10 px-5 py-4 text-sm">
        {t('legal.draftNotice')}
      </div>

      <div class="mt-8 space-y-4 leading-relaxed text-ink/90">
        <slot />
      </div>
    </div>
  </article>
</BaseLayout>
