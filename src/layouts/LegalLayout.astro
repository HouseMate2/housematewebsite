---
import BaseLayout from './BaseLayout.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

interface Props {
  title: string;
}
const { title } = Astro.props;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const updated = new Date().toLocaleDateString(lang === 'it' ? 'it-IT' : 'en-US');
---

<BaseLayout title={`${title} — HouseMate`}>
  <article class="section-y">
    <div class="container-page max-w-3xl">
      <h1 class="text-[clamp(2.25rem,5vw,3.25rem)]">{title}</h1>
      <p class="mt-3 text-sm text-muted">
        {lang === 'it' ? 'Ultimo aggiornamento' : 'Last updated'}: {updated}
      </p>

      <div class="mt-6 rounded-2xl border border-line bg-primary-soft px-5 py-4 text-sm text-ink">
        {t('legal.draftNotice')}
      </div>

      <div class="mt-8 space-y-4 leading-relaxed text-body">
        <slot />
      </div>
    </div>
  </article>
</BaseLayout>
