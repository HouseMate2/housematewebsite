---
import BaseLayout from './BaseLayout.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

interface Props {
  title: string;
  lastUpdated: string;
  effectiveDate?: string;
  version?: string;
  draft?: boolean;
}

const { title, lastUpdated, effectiveDate, version, draft = true } = Astro.props;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<BaseLayout title={`${title} - HouseMate`}>
  <article class="section-y">
    <div class="container-page max-w-3xl">
      <h1 class="text-[clamp(2.25rem,5vw,3.25rem)]">{title}</h1>
      <div class="mt-3 space-y-1 text-sm text-muted">
        <p>{lang === 'it' ? 'Ultimo aggiornamento' : 'Last updated'}: {lastUpdated}</p>
        {effectiveDate && <p>{lang === 'it' ? 'Data di efficacia' : 'Effective date'}: {effectiveDate}</p>}
        {version && <p>{lang === 'it' ? 'Versione' : 'Version'}: {version}</p>}
      </div>

      {
        draft && (
          <div class="mt-6 rounded-2xl border border-line bg-primary-soft px-5 py-4 text-sm text-ink">
            {t('legal.draftNotice')}
          </div>
        )
      }

      <div class="mt-8 space-y-5 leading-relaxed text-body [&_a]:font-semibold [&_a]:text-primary-dark [&_h2]:mt-10 [&_h2]:text-2xl [&_h2]:font-bold [&_h3]:mt-7 [&_h3]:text-xl [&_h3]:font-bold [&_li]:mt-2 [&_ol]:list-decimal [&_ol]:pl-6 [&_ul]:list-disc [&_ul]:pl-6">
        <slot />
      </div>
    </div>
  </article>
</BaseLayout>
