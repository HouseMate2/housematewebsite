---
// Bottoni di download (App Store / Google Play).
// ⚠️ TODO: sostituisci gli href "#" con i link reali agli store.
import { getLangFromUrl } from '../i18n/utils';

interface Props {
  class?: string;
}
const { class: cls = '' } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const small = lang === 'it' ? 'Scarica su' : 'Download on';
const smallG = lang === 'it' ? 'Disponibile su' : 'Get it on';
---

<div class={`flex flex-wrap items-center gap-3 ${cls}`}>
  <a href="#" class="btn-store" aria-label="App Store">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.09zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z" />
    </svg>
    <span class="flex flex-col text-left leading-none">
      <span class="text-[0.65rem] font-normal opacity-80">{small}</span>
      <span class="text-sm font-semibold">App Store</span>
    </span>
  </a>

  <a href="#" class="btn-store" aria-label="Google Play">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M3.6 2.3c-.3.3-.5.7-.5 1.3v16.8c0 .6.2 1 .5 1.3l11-11zM15.8 9.9 5.5 4.1l8.4 8.4zM18.9 11.5l-2.4-1.3-2.8 2.8 2.8 2.8 2.5-1.4c.8-.5.8-1.7-.1-2.9zM5.5 19.9l10.3-5.8-2-2z" />
    </svg>
    <span class="flex flex-col text-left leading-none">
      <span class="text-[0.65rem] font-normal opacity-80">{smallG}</span>
      <span class="text-sm font-semibold">Google Play</span>
    </span>
  </a>
</div>
