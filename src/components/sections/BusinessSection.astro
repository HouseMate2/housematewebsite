---
import { getLangFromUrl } from '../../i18n/utils';
import { homeContent } from '../../i18n/content';
import Icon from '../Icon.astro';
import ContactForm from '../ContactForm.astro';

const lang = getLangFromUrl(Astro.url);
const b = homeContent[lang].business;
---

<section id="business" class="section-y scroll-mt-28">
  <div class="container-page">
    <div class="panel bg-ink text-on-dark">
      <div class="grid gap-10 p-8 sm:p-12 md:grid-cols-2 lg:gap-16">
        <!-- Pitch proprietari -->
        <div class="md:self-center" data-animate="up">
          <span class="eyebrow">{b.eyebrow}</span>
          <h2 class="mt-3 max-w-md text-[clamp(1.9rem,3.5vw,2.9rem)] font-extrabold text-on-dark">
            {b.title}
          </h2>
          <p class="mt-4 max-w-md text-lg text-muted-on-dark">{b.text}</p>

          <ul class="mt-7 space-y-3">
            {
              b.bullets.map((item) => (
                <li class="flex items-start gap-3">
                  <span class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-primary text-on-primary">
                    <Icon name="check" class="h-4 w-4" />
                  </span>
                  <span class="text-on-dark">{item}</span>
                </li>
              ))
            }
          </ul>
        </div>

        <!-- Contatti (stessa pagina) -->
        <div id="contatti" class="scroll-mt-28 rounded-card bg-surface p-7 sm:p-8" data-animate="up">
          <span class="eyebrow">{b.contactEyebrow}</span>
          <h3 class="mt-2 text-2xl font-bold sm:text-3xl">{b.contactTitle}</h3>
          <p class="mt-3 text-muted">{b.contactText}</p>
          <ContactForm />
        </div>
      </div>
    </div>
  </div>
</section>
