---
import { getLangFromUrl } from '../../i18n/utils';
import { homeContent } from '../../i18n/content';

const lang = getLangFromUrl(Astro.url);
const stats = homeContent[lang].stats;
---

<section class="section-y">
  <div class="container-page">
    <div
      class="grid grid-cols-2 gap-8 rounded-card border border-line bg-surface px-8 py-12 md:grid-cols-4"
      data-animate="up"
    >
      {
        stats.map((s) => (
          <div class="text-center">
            <p class="font-display text-4xl font-bold text-primary sm:text-5xl">{s.value}</p>
            <p class="mt-2 text-sm text-muted">{s.label}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
