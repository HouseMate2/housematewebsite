---
import { getLangFromUrl } from '../../i18n/utils';
import { homeContent } from '../../i18n/content';
import StoreButtons from '../StoreButtons.astro';

const lang = getLangFromUrl(Astro.url);
const f = homeContent[lang].finalCta;
---

<section id="download" class="section-y scroll-mt-28">
  <div class="container-page">
    <div class="panel panel-peach px-8 py-16 text-center sm:py-20" data-animate="up">
      <h2 class="mx-auto max-w-2xl text-[clamp(2.25rem,5vw,3.75rem)] font-extrabold">{f.title}</h2>
      <p class="mx-auto mt-4 max-w-md text-lg text-muted">{f.subtitle}</p>
      <StoreButtons class="mt-9 justify-center" />
    </div>
  </div>
</section>
