---
import { getLangFromUrl } from '../../i18n/utils';
import { homeContent } from '../../i18n/content';

const lang = getLangFromUrl(Astro.url);
const c = homeContent[lang];
const cards = c.features.slice(0, 3);
const tints = ['panel-peach', 'panel-cream', 'panel-rose'];
const mockups = [
  {
    src: '/images/discovery houses.webp',
    alt: 'HouseMate app screen showing available rooms',
  },
  {
    src: '/images/discovery mates.webp',
    alt: 'HouseMate app screen showing roommate discovery',
  },
  {
    src: '/images/inquiry chat screen.webp',
    alt: 'HouseMate inquiry chat screen',
  },
];
const id = lang === 'it' ? 'funzionalita' : 'features';
---

<section id={id} class="section-y scroll-mt-28">
  <div class="container-page">
    <div class="mx-auto max-w-2xl text-center" data-animate="up">
      <span class="eyebrow">{c.featuresEyebrow}</span>
      <h2 class="mt-3 text-[clamp(2.1rem,4.5vw,3.25rem)] font-extrabold">{c.featuresTitle}</h2>
    </div>

    <div class="mt-14 grid gap-6 md:grid-cols-3">
      {
        cards.map((f, i) => (
          <div class={`panel ${tints[i % tints.length]} flex flex-col px-7 pt-8`} data-animate="up">
            <h3 class="text-2xl font-bold">{f.title}</h3>
            <p class="mt-3 text-muted">{f.text}</p>
            <div class="mx-auto -mb-14 mt-8 w-44">
              <img
                src={mockups[i % mockups.length].src}
                alt={mockups[i % mockups.length].alt}
                class="w-full drop-shadow-2xl"
                loading="lazy"
              />
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
