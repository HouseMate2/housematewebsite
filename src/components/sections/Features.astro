---
import { getLangFromUrl } from '../../i18n/utils';
import { homeContent } from '../../i18n/content';
import Icon from '../Icon.astro';
import DualPhone from '../DualPhone.astro';

const lang = getLangFromUrl(Astro.url);
const c = homeContent[lang];
const id = lang === 'it' ? 'funzionalita' : 'features';
---

<section id={id} class="section-y scroll-mt-28">
  <div class="container-page">
    <div class="mx-auto max-w-2xl text-center" data-animate="up">
      <span class="eyebrow">{c.featuresEyebrow}</span>
      <h2 class="mt-3 text-[clamp(2.1rem,4.5vw,3.25rem)] font-extrabold">{c.featuresTitle}</h2>
    </div>

    <div class="mt-14 flex flex-col gap-6">
      {
        c.panels.map((p, i) => (
          <div class={`panel ${p.tint}`} data-animate="up">
            <div class="grid items-center gap-8 px-8 pt-10 sm:px-14 sm:pt-16 md:grid-cols-2">
              <div class={`pb-10 sm:pb-16 md:self-center ${i % 2 === 1 ? 'md:order-2' : ''}`}>
                <span class="inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-surface text-primary shadow-card">
                  <Icon name={p.icon} class="h-6 w-6" />
                </span>
                <h3 class="mt-5 max-w-md text-[clamp(1.6rem,3vw,2.4rem)] font-bold">{p.title}</h3>
                <p class="mt-4 max-w-md text-lg text-muted">{p.text}</p>
              </div>

              <div class={`flex justify-center ${i % 2 === 1 ? 'md:order-1 md:justify-start' : 'md:justify-end'}`}>
                <DualPhone front={p.front} back={p.back} mirror={i % 2 === 1} />
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
