---
import { getLangFromUrl } from '../../i18n/utils';
import { homeContent } from '../../i18n/content';
import Icon from '../Icon.astro';

const lang = getLangFromUrl(Astro.url);
const c = homeContent[lang];
---

<section class="section-y">
  <div class="container-page">
    <div class="mx-auto max-w-2xl text-center" data-animate="up">
      <span class="eyebrow">{c.testimonialsEyebrow}</span>
      <h2 class="mt-3 text-[clamp(2.1rem,4.5vw,3.25rem)] font-extrabold">{c.testimonialsTitle}</h2>
    </div>

    <div class="mt-12 grid gap-6 md:grid-cols-3">
      {
        c.testimonials.map((t) => (
          <figure class="card flex flex-col p-7" data-animate="up">
            <span class="flex text-primary">
              {Array.from({ length: 5 }).map(() => <Icon name="star" class="h-4 w-4" />)}
            </span>
            <blockquote class="mt-4 flex-1 text-lg text-ink">“{t.quote}”</blockquote>
            <figcaption class="mt-6 flex items-center gap-3">
              <span class="flex h-10 w-10 items-center justify-center rounded-full bg-primary-soft font-semibold text-primary">
                {t.name.charAt(0)}
              </span>
              <span>
                <span class="block font-semibold text-ink">{t.name}</span>
                <span class="block text-sm text-muted">{t.role}</span>
              </span>
            </figcaption>
          </figure>
        ))
      }
    </div>
  </div>
</section>
