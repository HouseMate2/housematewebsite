---
// Sezione segnaposto riutilizzabile per la landing.
// Sostituisci il contenuto reale (testi, immagini, schede) man mano.
interface Props {
  id: string;
  eyebrow?: string;
  title: string;
  subtitle?: string;
  tint?: boolean;
}
const { id, eyebrow, title, subtitle, tint = false } = Astro.props;
---

<section id={id} class={`scroll-mt-20 py-20 md:py-28 ${tint ? 'bg-brand-50/40' : ''}`}>
  <div class="container-page" data-animate="up">
    {eyebrow && (
      <p class="text-sm font-semibold uppercase tracking-wider text-brand-600">{eyebrow}</p>
    )}
    <h2 class="mt-2 max-w-2xl text-3xl font-bold tracking-tight sm:text-4xl">{title}</h2>
    {subtitle && <p class="mt-4 max-w-2xl text-lg text-muted">{subtitle}</p>}

    <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {[1, 2, 3].map((n) => (
        <div class="rounded-2xl border border-black/5 bg-white p-6 shadow-sm" data-animate="up">
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-brand-100 text-brand-600 font-bold">
            {n}
          </div>
          <h3 class="mt-4 font-semibold">[ Titolo {n} ]</h3>
          <p class="mt-2 text-sm text-muted">[ Descrizione segnaposto. Sostituisci con i contenuti reali. ]</p>
        </div>
      ))}
    </div>
  </div>
</section>
