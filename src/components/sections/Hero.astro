---
import { getLangFromUrl, getRoutes } from '../../i18n/utils';
import { homeContent } from '../../i18n/content';
import Icon from '../Icon.astro';
import DualPhone from '../DualPhone.astro';

const lang = getLangFromUrl(Astro.url);
const r = getRoutes(lang);
const h = homeContent[lang].hero;

const front = {
  src: '/images/discovery houses iPhone.webp',
  alt: lang === 'it' ? 'Scopri le stanze disponibili' : 'Discover available rooms',
};
const back = {
  src: '/images/discovery mates iPhone.webp',
  alt: lang === 'it' ? 'Scopri i coinquilini' : 'Discover roommates',
};
---

<section class="relative overflow-x-hidden">
  <div
    class="pointer-events-none absolute inset-0 -z-10"
    style="background: radial-gradient(72% 56% at 50% -5%, var(--color-primary-soft) 0%, transparent 64%), var(--color-bg);"
    aria-hidden="true"
  >
  </div>

  <div class="container-page pt-16 text-center md:pt-24">
    <h1 class="mx-auto max-w-4xl text-[clamp(2.75rem,7vw,5rem)] font-extrabold" data-animate="up">
      {h.title} <span class="text-primary">{h.titleAccent}</span>
    </h1>

    <p class="mx-auto mt-6 max-w-xl text-lg text-muted" data-animate="up">{h.subtitle}</p>

    <div class="mt-9 flex flex-wrap items-center justify-center gap-3" data-animate="up">
      <a href={r.features} class="btn-primary">{h.ctaPrimary}</a>
      <a href={r.business} class="btn-secondary">{h.ctaSecondary}</a>
    </div>

    <p class="mt-5 inline-flex items-center gap-2 text-sm font-medium text-muted" data-animate="up">
      <Icon name="sparkle" class="h-4 w-4 text-primary" />
      {h.comingSoon}
    </p>

    <div class="mt-14 md:mt-18">
      <DualPhone front={front} back={back} size="lg" />
    </div>
  </div>
</section>
