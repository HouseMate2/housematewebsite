---
import { getLangFromUrl, useTranslations, getRoutes } from '../i18n/utils';
import LanguagePicker from './LanguagePicker.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const r = getRoutes(lang);

const links = [
  { href: r.features, label: t('nav.features') },
  { href: r.how, label: t('nav.how') },
  { href: r.business, label: t('nav.business') },
  { href: r.contact, label: t('nav.contact') },
];
---

<header class="sticky top-0 z-50 border-b border-black/5 bg-white/80 backdrop-blur-md">
  <nav class="container-page flex h-16 items-center justify-between">
    <a href={r.home} class="text-lg font-bold tracking-tight">
      House<span class="text-brand-500">Mate</span>
    </a>

    <!-- Link desktop -->
    <ul class="hidden items-center gap-8 md:flex">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              class="text-sm font-medium text-muted transition-colors hover:text-ink"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="flex items-center gap-3">
      <LanguagePicker />
      <a
        href={r.download}
        class="hidden rounded-full bg-brand-500 px-5 py-2 text-sm font-semibold text-white transition-colors hover:bg-brand-600 sm:inline-block"
      >
        {t('nav.download')}
      </a>

      <!-- Toggle mobile -->
      <button
        type="button"
        id="menu-toggle"
        class="inline-flex items-center justify-center rounded-md p-2 text-ink md:hidden"
        aria-label={t('nav.menu')}
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="4" y1="7" x2="20" y2="7"></line>
          <line x1="4" y1="12" x2="20" y2="12"></line>
          <line x1="4" y1="17" x2="20" y2="17"></line>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Menu mobile -->
  <div id="mobile-menu" class="hidden border-t border-black/5 bg-white md:hidden">
    <ul class="container-page flex flex-col gap-1 py-3">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              class="block rounded-lg px-2 py-2 text-base font-medium text-ink hover:bg-brand-50"
            >
              {link.label}
            </a>
          </li>
        ))
      }
      <li>
        <a
          href={r.download}
          class="mt-1 block rounded-full bg-brand-500 px-4 py-2 text-center text-base font-semibold text-white"
        >
          {t('nav.download')}
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(open));
  });
</script>
