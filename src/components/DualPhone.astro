---
// Mockup telefono: uno principale (`front`) e, opzionale, un secondo (`back`)
// che si sovrappone. Sullo scroll i due slittano in verticale in direzioni
// opposte (data-fx gestito da scripts/scrollFx.ts).
//   size:   'md' (pannelli) | 'lg' (hero, più grande)
//   mirror: true → il telefono secondario si sovrappone a SINISTRA (per le
//           sezioni con il mockup a sinistra, così l'overlap resta simmetrico)
interface Shot {
  src: string;
  alt: string;
}
interface Props {
  front: Shot;
  back?: Shot;
  size?: 'md' | 'lg';
  mirror?: boolean;
  class?: string;
}
const { front, back, size = 'md', mirror = false, class: cls = '' } = Astro.props;

const frontW =
  size === 'lg'
    ? 'w-[24rem] max-w-[92vw] sm:w-[30rem] md:w-[39rem]'
    : 'w-[22rem] max-w-[92vw] sm:w-[26rem] md:w-[32rem]';
const backW =
  size === 'lg'
    ? 'w-[18rem] max-w-[66vw] sm:w-[23rem] md:w-[29rem]'
    : 'w-[17rem] max-w-[66vw] sm:w-[22rem] md:w-[25rem]';
const backPos =
  mirror
    ? '-left-8 -top-9 sm:-left-16 md:-left-20'
    : '-right-8 -top-9 sm:-right-16 md:-right-20';
---

<div class={`relative mx-auto w-fit pb-14 sm:pb-18 md:pb-20 ${cls}`}>
  {
    back && (
      <img
        src={back.src}
        alt={back.alt}
        loading="lazy"
        data-fx="drift-down"
        class={`absolute z-0 ${backPos} ${backW} drop-shadow-2xl`}
      />
    )
  }
  <img
    src={front.src}
    alt={front.alt}
    loading="lazy"
    data-fx="drift-up"
    class={`relative z-10 ${frontW} drop-shadow-2xl`}
  />
</div>
