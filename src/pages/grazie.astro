---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Grazie - HouseMate">
  <section class="section-pad">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <p class="eyebrow">Messaggio inviato</p>
      <h1 class="mt-4 font-display text-4xl font-bold tracking-tight text-ink sm:text-5xl">
        Grazie, ti risponderemo presto.
      </h1>
      <p class="mx-auto mt-5 max-w-2xl text-lg leading-8 text-ink-muted">
        Abbiamo ricevuto la tua richiesta. Il team HouseMate la leggerà e ti contatterà appena possibile.
      </p>
      <a class="btn-primary mt-8 inline-flex" href="/">Torna alla home</a>
    </div>
  </section>
</BaseLayout>
