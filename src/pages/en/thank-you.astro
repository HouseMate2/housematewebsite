---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Thank you - HouseMate">
  <section class="section-pad">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <p class="eyebrow">Message sent</p>
      <h1 class="mt-4 font-display text-4xl font-bold tracking-tight text-ink sm:text-5xl">
        Thank you, we will get back to you soon.
      </h1>
      <p class="mx-auto mt-5 max-w-2xl text-lg leading-8 text-ink-muted">
        We received your request. The HouseMate team will read it and contact you as soon as possible.
      </p>
      <a class="btn-primary mt-8 inline-flex" href="/en/">Back to home</a>
    </div>
  </section>
</BaseLayout>
