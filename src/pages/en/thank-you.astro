---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Grazie - HouseMate">
  <section class="container-page flex min-h-[68vh] items-center justify-center py-28 sm:py-32 lg:py-36">
    <div class="mx-auto max-w-3xl text-center">
      <p class="eyebrow">Messaggio inviato</p>
      <h1 class="mx-auto mt-5 max-w-2xl text-[clamp(2.4rem,5vw,4.25rem)] font-extrabold text-ink">
        Grazie, ti risponderemo presto.
      </h1>
      <p class="mx-auto mt-6 max-w-xl text-lg leading-8 text-muted sm:text-xl">
        Abbiamo ricevuto la tua richiesta. Il team HouseMate la leggerà e ti contatterà appena possibile.
      </p>
      <a class="btn-primary mt-10" href="/">Torna alla home</a>
    </div>
  </section>
</BaseLayout>
