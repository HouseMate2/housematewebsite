---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Thank you - HouseMate">
  <section class="container-page flex min-h-[68vh] items-center justify-center py-28 sm:py-32 lg:py-36">
    <div class="mx-auto max-w-3xl text-center">
      <p class="eyebrow">Message sent</p>
      <h1 class="mx-auto mt-5 max-w-2xl text-[clamp(2.4rem,5vw,4.25rem)] font-extrabold text-ink">
        Thank you, we will get back to you soon.
      </h1>
      <p class="mx-auto mt-6 max-w-xl text-lg leading-8 text-muted sm:text-xl">
        We received your request. The HouseMate team will read it and contact you as soon as possible.
      </p>
      <a class="btn-primary mt-10" href="/en/">Back to home</a>
    </div>
  </section>
</BaseLayout>
