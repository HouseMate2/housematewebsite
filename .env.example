# Copia questo file in `.env` e compila i valori reali (il .env NON va su Git).
# Servirà nella Fase 5, quando colleghiamo il form contatti a un backend email.

# --- Esempio con Resend (https://resend.com) ---
# RESEND_API_KEY=
# CONTACT_TO_EMAIL=info@tuodominio.it

# --- Oppure, se usi Web3Forms (https://web3forms.com) niente .env serve:
#     basta incollare l'access key nell'action del form. ---
# PUBLIC_WEB3FORMS_KEY=
